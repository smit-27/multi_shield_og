# ── Blockchain Configuration (Ethereum Sepolia Testnet) ──
# Free public RPC — no account needed
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Your MetaMask wallet private key (the account that deployed the contract)
# ⚠️ NEVER commit this file with a real key — use .env only
WALLET_PRIVATE_KEY=your_wallet_private_key_here

# Deployed AuditLogStore contract address (from Remix IDE)
CONTRACT_ADDRESS=0x_your_deployed_contract_address
